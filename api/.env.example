# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Server Configuration
PORT=3001

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id

# Create Order feature: Telegram chat id of the orders group.
# Real group/supergroup ids are NEGATIVE (e.g. -1001234567890), not a positive
# 10-digit user id. Confirm via getUpdates/getChat before deploying.
ORDERS_GROUP_CHAT_ID=-100xxxxxxxxxxx
